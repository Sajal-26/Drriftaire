# --- SERVER CONFIG ---
NODE_ENV=production
PORT=3000
# Comma-separated list of allowed origins for CORS (required in production)
# Example: include every production frontend origin that may call this API.
# If your site is served from https://www.example.com, include the www origin too.
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://your-frontend-domain.vercel.app

# --- SUPABASE (PRIMARY DB) ---
# Get from Supabase project settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# --- ENCRYPTION & ADMIN ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-random-32-plus-char-string
ADMIN_EMAIL=admin@drriftaire.com
# Use ONLY ADMIN_PASSWORD_HASH in production (hashed format: salt:hash)
# Generate: node -e "const c = require('crypto'); const salt = c.randomBytes(16).toString('hex'); const hash = c.scryptSync('your-password', salt, 64).toString('hex'); console.log(salt + ':' + hash);"
ADMIN_PASSWORD_HASH=replace-with-salt:hash

# --- EMAIL (BREVO SMTP) ---
# Get from Brevo account settings
EMAIL_USER=your-brevo-email@example.com
EMAIL_PASS=your-brevo-smtp-password
